---
// FaqSection.astro — Bento Grid FAQ mit animierten Karten
// 3x2 Grid Desktop → 1-spaltig Mobile
---

<section class="py-20 lg:py-28" id="faq" aria-label="Häufige Fragen">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-[#0F172A] mb-4">
        Häufige Fragen – direkt beantwortet
      </h2>
    </div>

    <!-- Bento Grid: 3x2 Desktop, 1-spaltig Mobile -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

      <!-- FAQ 1: Local First -->
      <div class="bg-white rounded-2xl border border-[#E2E8F0] overflow-hidden transition-all duration-300 hover:shadow-lg bento-card" data-expanded="false">
        <button class="w-full text-left px-5 py-5 cursor-pointer" aria-expanded="false">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-gradient-to-br from-[#4D7CFF] to-[#22d3ee]">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between gap-2">
                <span class="text-base font-semibold text-[#0F172A] pr-2">Warum "Local First"?</span>
                <span class="bento-icon shrink-0 w-6 h-6 rounded-full flex items-center justify-center transition-transform duration-300 bg-[#E0E7FF] text-[#4D7CFF]">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <line x1="12" y1="5" x2="12" y2="19" stroke-width="2.5"/><line x1="5" y1="12" x2="19" y2="12" stroke-width="2.5"/>
                  </svg>
                </span>
              </div>
            </div>
          </div>
        </button>
        <div class="bento-answer max-h-0 overflow-hidden transition-all duration-400 ease-in-out">
          <div class="px-5 pb-5 pt-0 text-sm text-[#475569] leading-relaxed border-t border-[#E2E8F0] mx-5 pt-4">
            Wir hosten alle Dateien direkt bei uns. Das bedeutet: keine externen Google-Schriften, kein Amazon-Cloud-Tool, kein US-Tracker. Ihre Seite lädt tendenziell schneller und gibt weniger Daten an Dritte weiter.
          </div>
        </div>
      </div>

      <!-- FAQ 2: Kosten -->
      <div class="bg-white rounded-2xl border border-[#E2E8F0] overflow-hidden transition-all duration-300 hover:shadow-lg bento-card" data-expanded="false">
        <button class="w-full text-left px-5 py-5 cursor-pointer" aria-expanded="false">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-gradient-to-br from-[#4D7CFF] to-[#22d3ee]">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between gap-2">
                <span class="text-base font-semibold text-[#0F172A] pr-2">Was kostet eine Website bei Ihnen?</span>
                <span class="bento-icon shrink-0 w-6 h-6 rounded-full flex items-center justify-center transition-transform duration-300 bg-[#E0E7FF] text-[#4D7CFF]">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <line x1="12" y1="5" x2="12" y2="19" stroke-width="2.5"/><line x1="5" y1="12" x2="19" y2="12" stroke-width="2.5"/>
                  </svg>
                </span>
              </div>
            </div>
          </div>
        </button>
        <div class="bento-answer max-h-0 overflow-hidden transition-all duration-400 ease-in-out">
          <div class="px-5 pb-5 pt-0 text-sm text-[#475569] leading-relaxed border-t border-[#E2E8F0] mx-5 pt-4">
            Digital Start ist eine statische Website zum Festpreis – ohne laufende Kosten. Digital Flex hat einmalige Einrichtungskosten plus optional eine Hosting- und Betreuungspauschale. Sie bekommen vorab ein verbindliches Angebot.
          </div>
        </div>
      </div>

      <!-- FAQ 3: Updates -->
      <div class="bg-white rounded-2xl border border-[#E2E8F0] overflow-hidden transition-all duration-300 hover:shadow-lg bento-card" data-expanded="false">
        <button class="w-full text-left px-5 py-5 cursor-pointer" aria-expanded="false">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-gradient-to-br from-[#4D7CFF] to-[#22d3ee]">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between gap-2">
                <span class="text-base font-semibold text-[#0F172A] pr-2">Kümmere ich mich selbst um Updates?</span>
                <span class="bento-icon shrink-0 w-6 h-6 rounded-full flex items-center justify-center transition-transform duration-300 bg-[#E0E7FF] text-[#4D7CFF]">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <line x1="12" y1="5" x2="12" y2="19" stroke-width="2.5"/><line x1="5" y1="12" x2="19" y2="12" stroke-width="2.5"/>
                  </svg>
                </span>
              </div>
            </div>
          </div>
        </button>
        <div class="bento-answer max-h-0 overflow-hidden transition-all duration-400 ease-in-out">
          <div class="px-5 pb-5 pt-0 text-sm text-[#475569] leading-relaxed border-t border-[#E2E8F0] mx-5 pt-4">
            Bei Digital Start läuft die Seite weitgehend von alleine. Bei Digital Flex haben Sie ein eigenes CMS, mit dem Sie Texte und Bilder selbst ändern können (wir zeigen Ihnen wie). Auf Wunsch übernehmen wir auch die Pflege.
          </div>
        </div>
      </div>

      <!-- FAQ 4: Fehlerfall -->
      <div class="bg-white rounded-2xl border border-[#E2E8F0] overflow-hidden transition-all duration-300 hover:shadow-lg bento-card" data-expanded="false">
        <button class="w-full text-left px-5 py-5 cursor-pointer" aria-expanded="false">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-gradient-to-br from-[#4D7CFF] to-[#22d3ee]">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between gap-2">
                <span class="text-base font-semibold text-[#0F172A] pr-2">Was passiert, wenn mal etwas nicht funktioniert?</span>
                <span class="bento-icon shrink-0 w-6 h-6 rounded-full flex items-center justify-center transition-transform duration-300 bg-[#E0E7FF] text-[#4D7CFF]">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <line x1="12" y1="5" x2="12" y2="19" stroke-width="2.5"/><line x1="5" y1="12" x2="19" y2="12" stroke-width="2.5"/>
                  </svg>
                </span>
              </div>
            </div>
          </div>
        </button>
        <div class="bento-answer max-h-0 overflow-hidden transition-all duration-400 ease-in-out">
          <div class="px-5 pb-5 pt-0 text-sm text-[#475569] leading-relaxed border-t border-[#E2E8F0] mx-5 pt-4">
            Sie schreiben eine E-Mail oder rufen an. Wir kümmern uns darum – persönlich, ohne Ticket-System, ohne Chatbot. Ein Mensch, der Ihr Projekt kennt, antwortet Ihnen.
          </div>
        </div>
      </div>

      <!-- FAQ 5: Bindung -->
      <div class="bg-white rounded-2xl border border-[#E2E8F0] overflow-hidden transition-all duration-300 hover:shadow-lg bento-card" data-expanded="false">
        <button class="w-full text-left px-5 py-5 cursor-pointer" aria-expanded="false">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-gradient-to-br from-[#4D7CFF] to-[#22d3ee]">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between gap-2">
                <span class="text-base font-semibold text-[#0F172A] pr-2">Bin ich danach an Sie gebunden?</span>
                <span class="bento-icon shrink-0 w-6 h-6 rounded-full flex items-center justify-center transition-transform duration-300 bg-[#E0E7FF] text-[#4D7CFF]">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <line x1="12" y1="5" x2="12" y2="19" stroke-width="2.5"/><line x1="5" y1="12" x2="19" y2="12" stroke-width="2.5"/>
                  </svg>
                </span>
              </div>
            </div>
          </div>
        </button>
        <div class="bento-answer max-h-0 overflow-hidden transition-all duration-400 ease-in-out">
          <div class="px-5 pb-5 pt-0 text-sm text-[#475569] leading-relaxed border-t border-[#E2E8F0] mx-5 pt-4">
            Nein. Ihre Website gehört Ihnen. Der Code basiert auf offenen Standards – andere Entwickler können daran weiterarbeiten. Ein Wechsel ist jederzeit möglich.
          </div>
        </div>
      </div>

      <!-- FAQ 6: Domain & Hosting -->
      <div class="bg-white rounded-2xl border border-[#E2E8F0] overflow-hidden transition-all duration-300 hover:shadow-lg bento-card" data-expanded="false">
        <button class="w-full text-left px-5 py-5 cursor-pointer" aria-expanded="false">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-gradient-to-br from-[#4D7CFF] to-[#22d3ee]">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between gap-2">
                <span class="text-base font-semibold text-[#0F172A] pr-2">Übernehmen Sie auch Domain und Hosting?</span>
                <span class="bento-icon shrink-0 w-6 h-6 rounded-full flex items-center justify-center transition-transform duration-300 bg-[#E0E7FF] text-[#4D7CFF]">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <line x1="12" y1="5" x2="12" y2="19" stroke-width="2.5"/><line x1="5" y1="12" x2="19" y2="12" stroke-width="2.5"/>
                  </svg>
                </span>
              </div>
            </div>
          </div>
        </button>
        <div class="bento-answer max-h-0 overflow-hidden transition-all duration-400 ease-in-out">
          <div class="px-5 pb-5 pt-0 text-sm text-[#475569] leading-relaxed border-t border-[#E2E8F0] mx-5 pt-4">
            Ja, wir richten alles ein. Die Domain wird auf Ihren Namen registriert, das Hosting läuft in deutschen Rechenzentren (IONOS). Sie bleiben Eigentümer.
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  (function() {
    document.querySelectorAll('.bento-card button').forEach(btn => {
      btn.addEventListener('click', function() {
        const card = this.closest('.bento-card');
        const answer = card.querySelector('.bento-answer');
        const icon = card.querySelector('.bento-icon');
        const isOpen = this.getAttribute('aria-expanded') === 'true';

        if (isOpen) {
          // Close
          this.setAttribute('aria-expanded', 'false');
          card.setAttribute('data-expanded', 'false');
          answer.style.maxHeight = '0';
          icon.querySelector('svg').innerHTML = '<line x1="12" y1="5" x2="12" y2="19" stroke-width="2.5"/><line x1="5" y1="12" x2="19" y2="12" stroke-width="2.5"/>';
          card.style.borderLeftColor = '';
          card.style.borderLeftWidth = '1px';
        } else {
          // Open
          this.setAttribute('aria-expanded', 'true');
          card.setAttribute('data-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 40 + 'px';
          icon.querySelector('svg').innerHTML = '<line x1="5" y1="12" x2="19" y2="12" stroke-width="2.5"/>';
          card.style.borderLeftColor = '#4D7CFF';
          card.style.borderLeftWidth = '3px';
        }
      });
    });
  })();
</script>

<style>
  .bento-card {
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    border-left: 1px solid #E2E8F0;
  }
  .bento-card:hover {
    transform: translateY(-2px);
  }
  .bento-card[data-expanded="true"] {
    border-left: 3px solid #4D7CFF;
  }
  .bento-icon {
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .bento-card[data-expanded="true"] .bento-icon {
    background: #4D7CFF;
    color: white;
  }
  .bento-answer {
    transition: max-height 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
</style>
