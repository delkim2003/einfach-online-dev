---

<section class="py-20 lg:py-28 section-padding" id="preise" aria-label="Preise">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-text-primary mb-4" style="font-family: 'Geist', sans-serif;">
        Transparente Preise für Ihren Erfolg.
      </h2>
