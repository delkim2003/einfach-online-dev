        Transparente Investition, keine Überraschungen.
      </p>
    </div>

    <!-- Toggle-Buttons -->
    <div class="flex justify-center mb-12">
      <div class="inline-flex items-center bg-[#F0F4F8] rounded-xl p-1 shadow-sm border border-[#E2E8F0]">
        <button
          id="toggle-kaufen"
          class="toggle-btn px-5 py-2.5 rounded-lg text-sm font-semibold transition-all duration-300 bg-[#4D7CFF] text-white shadow-sm min-h-[44px] flex items-center justify-center"
          data-target="kaufen"
        >
          Kaufen & Pflegen
        </button>
        <button
          id="toggle-mieten"
          class="toggle-btn px-5 py-2.5 rounded-lg text-sm font-semibold transition-all duration-300 text-[#475569] hover:text-[#0F172A] min-h-[44px] flex items-center justify-center"
          data-target="mieten"
        >
          Mieten · ALL-IN
        </button>
      </div>
    </div>

    <!-- KAUFEN State (default visible) -->
    <div id="state-kaufen" class="toggle-state">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">

        <!-- Card: Digital Start -->
