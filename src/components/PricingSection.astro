---
// PricingSection.astro — ALPINE: TOGGLE KAUFEN/MIETEN
// Toggle-Button in EO-Blau, 2 Cards nebeneinander
// Kein client:load nötig — reines CSS + minimales Inline-Script
---

<section class="py-20 lg:py-28" id="preise" aria-label="Preise">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-[#0F172A] mb-4">
        Investition &amp; <span class="text-[#4D7CFF]">Transparenz</span>
      </h2>
