            <span class="inline-block text-[11px] font-semibold uppercase tracking-widest text-[#4D7CFF] bg-[#4D7CFF]/8 px-3 py-1.5 rounded-full border border-[#4D7CFF]/15">
              Für den Einstieg
            </span>
          </div>
          <h3 class="text-2xl font-bold text-[#0F172A] mb-1" style="font-family: 'Geist', 'Inter', sans-serif;">Digital Start</h3>
          <div class="flex items-baseline gap-1 mb-4">
            <span class="text-4xl font-black text-[#0F172A]" style="font-family: 'Geist', 'Inter', sans-serif;">ab € 1.490,–</span>
            <span class="text-sm text-[#475569]"> einmalig</span>
          </div>
          <ul class="space-y-3 mb-6 flex-1">
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#4D7CFF]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Cookie-freie DSGVO-konforme Website</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#4D7CFF]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Statisch generiert (Astro SSG)</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#4D7CFF]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>EU-Hosting (Deutschland)</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#4D7CFF]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Individuelles Tailwind CSS</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#4D7CFF]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Google-optimiert</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#4D7CFF]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Persönlicher Ansprechpartner</span>
            </li>
          </ul>
          <div class="border-t border-[#E2E8F0] pt-4 mb-5">
            <p class="text-xs text-[#475569]">
              <span class="font-semibold text-[#4D7CFF]">Online Guardian</span> – €39–€59 / Monat – Wartung & Updates.
            </p>
          </div>
          <a href="/kontakt" class="inline-flex items-center justify-center px-6 py-3 bg-[#4D7CFF] text-white text-sm font-semibold rounded-xl shadow-[0_4px_16px_rgba(77,124,255,0.25)] hover:bg-[#3B6BF5] hover:shadow-[0_6px_24px_rgba(77,124,255,0.35)] transition-all duration-300 ease-out hover:-translate-y-0.5 w-full text-center">
            START anfragen
          </a>
        </div>

        <!-- Card: Digital Flex (Bestseller) -->
        <div class="relative bg-white rounded-xl shadow-[0_4px_24px_rgba(0,0,0,0.06)] border border-[#E2E8F0] p-8 flex flex-col ring-2 ring-[#4D7CFF]/20">
          <div class="absolute top-4 right-4">
            <span class="inline-block text-[11px] font-semibold uppercase tracking-widest text-white bg-[#4D7CFF] px-3 py-1.5 rounded-full shadow-sm">
              Bestseller
            </span>
          </div>
          <h3 class="text-2xl font-bold text-[#0F172A] mb-1" style="font-family: 'Geist', 'Inter', sans-serif;">Digital Flex</h3>
          <div class="flex items-baseline gap-1 mb-4">
            <span class="text-4xl font-black text-[#0F172A]" style="font-family: 'Geist', 'Inter', sans-serif;">ab € 2.990,–</span>
            <span class="text-sm text-[#475569]"> einmalig</span>
          </div>
          <ul class="space-y-3 mb-6 flex-1">
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#4D7CFF]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>ALLES von Digital Start</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#4D7CFF]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>CMS-Integration</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#4D7CFF]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Inhalte selbst bearbeiten</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#4D7CFF]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Blog / News / Portfolio</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#4D7CFF]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>MySQL-Datenbank</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#4D7CFF]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Skalierbar</span>
            </li>
          </ul>
          <div class="border-t border-[#E2E8F0] pt-4 mb-5">
            <p class="text-xs text-[#475569]">
              <span class="font-semibold text-[#4D7CFF]">Online Care</span> – €99–€149 / Monat – Wartung, Updates & Support.
            </p>
          </div>
          <a href="/kontakt" class="inline-flex items-center justify-center px-6 py-3 bg-transparent text-[#4D7CFF] text-sm font-semibold rounded-xl border-2 border-[#4D7CFF] hover:bg-[#4D7CFF]/5 transition-all duration-300 ease-out hover:-translate-y-0.5 w-full text-center">
            FLEX anfragen
          </a>
        </div>

      </div>
    </div>

    <!-- MIETEN State (hidden by default) -->
    <div id="state-mieten" class="toggle-state hidden">
      <div class="max-w-md mx-auto">
        <!-- Card: ALL-IN SMART -->
        <div class="relative bg-white rounded-xl shadow-[0_4px_24px_rgba(0,0,0,0.06)] border border-[#E2E8F0] p-8 flex flex-col">
          <div class="absolute top-4 right-4">
            <span class="inline-block text-[11px] font-semibold uppercase tracking-widest text-[#22d3ee] bg-[#22d3ee]/8 px-3 py-1.5 rounded-full border border-[#22d3ee]/20">
              All-inclusive
            </span>
          </div>
          <h3 class="text-2xl font-bold text-[#0F172A] mb-1" style="font-family: 'Geist', 'Inter', sans-serif;">ALL-IN SMART</h3>
          <div class="flex items-baseline gap-1 mb-1">
            <span class="text-4xl font-black text-[#0F172A]" style="font-family: 'Geist', 'Inter', sans-serif;">€ 149–€199</span>
            <span class="text-sm text-[#475569]"> / Monat</span>
          </div>
          <p class="text-xs text-[#475569] mb-6">€ 399 einmalige Bereitstellung</p>
          <ul class="space-y-3 mb-6 flex-1">
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#22d3ee]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>DSGVO-konforme Website</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#22d3ee]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Persönliche Betreuung</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#22d3ee]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Hosting inklusive</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#22d3ee]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Wartung & Updates</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#22d3ee]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Content-Pflege</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[#475569]">
              <svg class="mt-0.5 shrink-0 text-[#22d3ee]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Priorisierter Support</span>
            </li>
          </ul>
          <a href="/kontakt" class="inline-flex items-center justify-center px-6 py-3 bg-[#4D7CFF] text-white text-sm font-semibold rounded-xl shadow-[0_4px_16px_rgba(77,124,255,0.25)] hover:bg-[#3B6BF5] hover:shadow-[0_6px_24px_rgba(77,124,255,0.35)] transition-all duration-300 ease-out hover:-translate-y-0.5 w-full text-center">
            ALL-IN anfragen
          </a>
        </div>
      </div>
    </div>

    <!-- Footer-Text-Hinweis -->
    <p class="text-center text-[#475569] text-sm mt-10 max-w-2xl mx-auto">
      Umsatzsteuerbefreit – Kleinunternehmer §6 UStG. Bindung: 24 Monate (Miet-Modell).
    </p>
  </div>
</section>

<script>
  (function() {
    const btns = document.querySelectorAll('.toggle-btn');
    const kaufenState = document.getElementById('state-kaufen');
    const mietenState = document.getElementById('state-mieten');

    btns.forEach(btn => {
      btn.addEventListener('click', function() {
        const target = this.dataset.target;

        // Reset all buttons
        btns.forEach(b => {
          b.classList.remove('bg-[#4D7CFF]', 'text-white', 'shadow-sm');
          b.classList.add('text-[#475569]');
        });

        // Activate clicked button
        this.classList.add('bg-[#4D7CFF]', 'text-white', 'shadow-sm');
        this.classList.remove('text-[#475569]');

        // Toggle states
        if (target === 'kaufen') {
          kaufenState.classList.remove('hidden');
          mietenState.classList.add('hidden');
        } else {
          mietenState.classList.remove('hidden');
          kaufenState.classList.add('hidden');
        }
      });
    });
  })();
</script>
