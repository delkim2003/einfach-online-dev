---
// SoLauftEsSection.astro — ALPINE TERMINAL: PIPELINE
// 4 Schritte als Pipeline: [INIT] → [CODE] → [TEST] → [SHIP]
---

<section class="py-20 lg:py-28 section-padding animate-on-scroll" id="ablauf" aria-label="So läuft's">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-text-primary mb-4">
        So <span class="text-[#4D7CFF]">läuft's</span>
      </h2>
      <p class="text-text-secondary text-base sm:text-lg max-w-2xl mx-auto">
        Vier Schritte von der Idee bis zur sichtbaren Website
      </p>
    </div>

    <div class="pipeline">
      <!-- Step 1: INIT -->
      <div class="pipeline-step animate-on-scroll delay-100">
        <div class="pipeline-box">
          <div class="pipeline-status">
            <span class="pipeline-status-dot"></span>
            running
          </div>
          <div class="pipeline-title">INIT</div>
          <div class="pipeline-desc">Gespräch &amp; Konzept</div>
        </div>
      </div>
      <div class="pipeline-arrow" aria-hidden="true"></div>

      <!-- Step 2: CODE -->
      <div class="pipeline-step animate-on-scroll delay-200">
        <div class="pipeline-box">
          <div class="pipeline-status">
            <span class="pipeline-status-dot"></span>
            running
          </div>
          <div class="pipeline-title">CODE</div>
          <div class="pipeline-desc">Design &amp; Entwicklung</div>
        </div>
      </div>
      <div class="pipeline-arrow" aria-hidden="true"></div>

      <!-- Step 3: TEST -->
      <div class="pipeline-step animate-on-scroll delay-300">
        <div class="pipeline-box">
          <div class="pipeline-status">
            <span class="pipeline-status-dot"></span>
            running
          </div>
          <div class="pipeline-title">TEST</div>
          <div class="pipeline-desc">SEO &amp; Qualitätssicherung</div>
        </div>
      </div>
      <div class="pipeline-arrow" aria-hidden="true"></div>

      <!-- Step 4: SHIP -->
      <div class="pipeline-step animate-on-scroll delay-400">
        <div class="pipeline-box">
          <div class="pipeline-status">
            <span class="pipeline-status-dot"></span>
            running
          </div>
          <div class="pipeline-title">SHIP</div>
          <div class="pipeline-desc">Livegang &amp; Wachstum</div>
        </div>
      </div>
    </div>
  </div>
</section>
