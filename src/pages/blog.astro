---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
---

<Layout 
  title="Blog | einfach-online.dev"
  description="Artikel zu Webentwicklung, SEO, GEO und modernen Technologien. Persönlich betreut von Philipp Schlemmer in der Steiermark."
  canonical="https://einfach-online.dev/blog"
>
  <Header />
  
  <main class="pt-20">
    <!-- Blog Hero -->
    <section class="py-20 lg:py-28 section-padding text-center" aria-label="Blog Übersicht">
      <div class="max-w-3xl mx-auto">
        <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-accent-blue/10 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#4D7CFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/>
          </svg>
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-text-primary mb-4" style="font-family: 'Geist', sans-serif;">
          KMU-Website-Ratgeber
        </h1>
        <p class="text-text-secondary text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
          Praktische Tipps zu Google-Suche, KI-Sichtbarkeit, DSGVO und Website-Optimierung. Ohne Fachchinesisch. Ohne Werbung.
        </p>
      </div>
    </section>
    
    <!-- Erster Blog-Artikel -->
    <section class="pb-20 lg:pb-28 section-padding" aria-label="Blog-Artikel">
      <div class="max-w-3xl mx-auto">
        <article class="bento-tile">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-accent-blue/10 text-accent-blue text-xs font-medium">SEO & GEO</span>
            <span class="text-xs text-text-secondary">Juni 2026</span>
          </div>
          <h2 class="text-xl sm:text-2xl font-bold text-text-primary mb-3" style="font-family: 'Geist', sans-serif;">
            Wie Sie in Google und KI-Suche gefunden werden – ein Leitfaden für kleine Unternehmen
          </h2>
          <p class="text-text-secondary text-sm leading-relaxed">
            In Kürze erscheint hier der erste ausführliche Artikel. Ich arbeite daran, Ihnen praktische Tipps zu liefern, 
            wie Sie Ihre Website für Google und KI-gestützte Suchmaschinen optimieren können – ohne kompliziertes Fachchinesisch.
          </p>
        </article>
      </div>
    </section>
  </main>
  
  <Footer />
  <CookieBanner />
</Layout>
