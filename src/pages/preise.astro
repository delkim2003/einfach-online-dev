---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Preise"
  description="Transparente Preise für Ihre Webseite. Digital Start, Digital Flex oder ALL-IN SMART – das passende Paket für Ihr Unternehmen."
  canonical="https://einfach-online.dev/leistungen"
  noindex={true}
>
  <meta http-equiv="refresh" content="0; url=/leistungen/" />
  
  <main class="pt-20 min-h-screen flex items-center justify-center bg-white">
    <div class="text-center px-4">
      <h1 class="text-2xl font-bold text-[#0F172A] mb-4">Preise & Pakete</h1>
      <p class="text-[#475569] mb-6">Die Preisübersicht findest du auf unserer <a href="/leistungen" class="text-[#4D7CFF] hover:underline">Leistungsseite</a>.</p>
      <p class="text-sm text-[#94A3B8">Weiterleitung... <a href="/leistungen" class="text-[#4D7CFF] hover:underline">Hier klicken</a></p>
    </div>
  </main>
</Layout>
