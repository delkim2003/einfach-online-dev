---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import Logo from '../components/Logo.astro';
---

<Layout 
  title="Über mich | einfach-online.dev"
  description="Philipp Schlemmer – Webentwickler und SEO-Spezialist aus Gleisdorf, Steiermark. Persönliche Betreuung statt Callcenter."
  canonical="https://einfach-online.dev/ueber-mich"
>
  <Header />
  
  <main class="pt-20">
    <section class="py-20 lg:py-28 section-padding" aria-label="Über Philipp Schlemmer">
      <div class="max-w-6xl mx-auto">
        <!-- Hero -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center mb-20">
          <div>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-text-primary mb-6" style="font-family: 'Geist', sans-serif; letter-spacing: -0.04em;">
              Hi, ich bin Philipp.<br />
              <span class="gradient-text">Ihr Partner für</span><br />
              <span class="gradient-text">Web & SEO</span> in der<br />
              Steiermark.
            </h1>
            <p class="text-text-secondary leading-relaxed">
              Als Einzelkämpfer mit einem starken Netzwerk im Rücken baue ich digitale Erlebnisse, 
              die nicht nur gut aussehen, sondern auch messbar performen. Direkter Kontakt, 
              kein Agentur-Overhead, volle Transparenz.
            </p>
          </div>
          
          <div class="relative aspect-[4/5] max-w-md mx-auto lg:max-w-none">
            <div class="absolute inset-0 bg-gradient-to-br from-accent-blue/20 via-accent-blue/20 to-accent-cyan/20 rounded-2xl blur-3xl opacity-50" aria-hidden="true"></div>
            <div class="relative bento-tile h-full flex items-center justify-center min-h-[400px]">
              <div class="text-center">
                <div class="w-32 h-32 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-accent-blue to-accent-blue flex items-center justify-center p-4">
                  <Logo class="w-24 h-auto" />
                </div>
                <p class="text-text-primary font-bold text-xl" style="font-family: 'Geist', sans-serif;">Philipp Schlemmer</p>
                <p class="text-text-secondary text-sm mt-1">Webentwickler & SEO-Spezialist</p>
                <p class="text-text-secondary text-xs mt-1">Gleisdorf, Steiermark</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Stats / Features -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-20">
          <article class="bento-tile text-center">
            <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-accent-blue/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4D7CFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-text-primary mb-2" style="font-family: 'Geist', sans-serif;">Persönliche Betreuung</h3>
            <p class="text-text-secondary text-sm leading-relaxed">
              Direkter Kontakt, kein Agentur-Overhead, volle Transparenz. Ich bin persönlich für Sie da – von der ersten Idee bis zur fertigen Website und darüber hinaus.
            </p>
          </article>
          
          <article class="bento-tile text-center">
            <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-accent-blue/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4D7CFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-text-primary mb-2" style="font-family: 'Geist', sans-serif;">15+ Jahre Erfahrung</h3>
            <p class="text-text-secondary text-sm leading-relaxed">
              Seit über einem Jahrzehnt im Web unterwegs. Ich kenne die Trends, aber noch wichtiger: Ich weiß, was nachhaltig funktioniert und was nicht.
            </p>
          </article>
          
          <article class="bento-tile text-center">
            <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-accent-cyan/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#29C5F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-text-primary mb-2" style="font-family: 'Geist', sans-serif;">Regionale Expertise</h3>
            <p class="text-text-secondary text-sm leading-relaxed">
              Aus der Steiermark für Unternehmen in ganz Österreich. Ich kenne den lokalen Markt und die Herausforderungen, vor denen kleine und mittlere Unternehmen stehen.
            </p>
          </article>
        </div>
        
        <!-- Arbeitsweise -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-20">
          <div class="bento-tile">
            <h2 class="text-2xl font-bold text-text-primary mb-6" style="font-family: 'Geist', sans-serif;">
              Meine Arbeitsweise
            </h2>
            <ul class="space-y-6">
              <li>
                <h3 class="text-sm font-semibold text-accent-blue mb-1 flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent-blue"></span>
                  Transparenz First
                </h3>
                <p class="text-text-secondary text-sm leading-relaxed">
                  Klare Angebote, ehrliche Einschätzungen und regelmäßige Updates. Sie wissen immer, woran ich arbeite und wofür Sie bezahlen.
                </p>
              </li>
              <li>
                <h3 class="text-sm font-semibold text-accent-blue mb-1 flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent-blue"></span>
                  Fokus auf Performance
                </h3>
                <p class="text-text-secondary text-sm leading-relaxed">
                  Eine schöne Website reicht nicht. Sie muss schnell laden, auf allen Geräten funktionieren und von Google gefunden werden. Das ist mein Standard.
                </p>
              </li>
              <li>
                <h3 class="text-sm font-semibold text-accent-cyan mb-1 flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent-cyan"></span>
                  Moderne Technologien
                </h3>
                <p class="text-text-secondary text-sm leading-relaxed">
                  Ich nutze aktuelle, aber erprobte Stacks (wie diesen Dark Swiss UI Ansatz), um langlebige und skalierbare digitale Produkte zu bauen.
                </p>
              </li>
            </ul>
          </div>
          
          <div class="bento-tile flex flex-col justify-center">
            <h2 class="text-2xl font-bold text-text-primary mb-3" style="font-family: 'Geist', sans-serif;">
              Lass uns starten.
            </h2>
            <p class="text-text-secondary text-sm leading-relaxed mb-6">
              Bereit für den nächsten Schritt? Kontaktieren Sie mich direkt.
            </p>
            <div class="space-y-3">
              <a href="mailto:info@einfach-online.dev" class="flex items-center gap-3 p-3 rounded-xl bg-surface-container border border-border-subtle hover:border-accent-blue/30 transition-colors">
                <div class="w-8 h-8 rounded-lg bg-accent-blue/10 flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4D7CFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                <span class="text-sm font-medium text-text-primary">E-Mail schreiben</span>
              </a>
              <a href="tel:+436641234567" class="flex items-center gap-3 p-3 rounded-xl bg-surface-container border border-border-subtle hover:border-accent-blue/30 transition-colors">
                <div class="w-8 h-8 rounded-lg bg-accent-blue/10 flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4D7CFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <span class="text-sm font-medium text-text-primary">Anrufen</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <CookieBanner />
</Layout>
