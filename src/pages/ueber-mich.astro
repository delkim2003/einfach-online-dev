---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
---

<Layout 
  title="Über mich"
  description="Philipp Schlemmer – Webentwickler und SEO-Spezialist aus Gleisdorf, Steiermark. Persönliche Betreuung statt Callcenter."
  canonical="https://einfach-online.dev/ueber-mich"
>
  <Header />

  <main class="pt-20">
    <!-- Hero -->
    <section class="py-12 lg:py-16 section-padding bg-gradient-to-b from-[#F8FAFC] to-white">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12 items-center">
          <!-- Links: Terminal-Code -->
          <div class="lg:col-span-3 order-2 lg:order-1">
            <div class="font-mono text-sm leading-relaxed">
              <div class="flex items-center gap-2 mb-4 text-[#64748B]">
                <span class="text-[#4D7CFF] font-semibold">terminal</span>
                <span class="text-[#94A3B8]">— bash</span>
              </div>

              <div class="bg-[#0F172A] rounded-xl p-5 sm:p-6 shadow-lg border border-[#1E293B]">
                <p class="text-[#94A3B8] mb-2"><span class="text-[#22d3ee]">$</span> <span class="text-[#E2E8F0]">cat über-mich.txt</span></p>
                <p class="text-[#94A3B8] mb-1"><span class="text-[#4D7CFF]">></span> Name: <span class="text-[#E2E8F0]">Philipp Schlemmer</span></p>
                <p class="text-[#94A3B8] mb-1"><span class="text-[#4D7CFF]">></span> Standort: <span class="text-[#E2E8F0]">Gleisdorf, Steiermark</span></p>
                <p class="text-[#94A3B8] mb-1"><span class="text-[#4D7CFF]">></span> Erfahrung: <span class="text-[#E2E8F0]">15+ Jahre Webentwicklung</span></p>
                <p class="text-[#94A3B8] mb-1"><span class="text-[#4D7CFF]">></span> Fokus: <span class="text-[#E2E8F0]">DSGVO, Performance, GEO</span></p>
                <p class="text-[#94A3B8]"><span class="text-[#4D7CFF]">></span> Tools: <span class="text-[#E2E8F0]">Astro, Drupal, Tailwind, SEO</span></p>
                <p class="text-[#22d3ee] mt-3"><span class="text-[#22d3ee]">$</span> <span class="animate-pulse">_</span></p>
              </div>
            </div>
          </div>

          <!-- Rechts: Persönliche Info -->
          <div class="lg:col-span-2 order-1 lg:order-2">
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-[#0F172A] mb-4" style="font-family: 'Geist', sans-serif; letter-spacing: -0.04em;">
              Persönliche Betreuung<br />
              <span class="text-[#4D7CFF]">statt Callcenter.</span>
            </h1>
            <p class="text-[#475569] text-base sm:text-lg mb-4 leading-relaxed">
              Kein Ticket-System. Keine Chatbots. Nur ein Mensch, der Ihr Projekt kennt.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Über mich Text -->
    <section class="py-16 lg:py-20 section-padding bg-white">
      <div class="max-w-4xl mx-auto">
        <div class="prose max-w-none">
          <p class="text-[#334155] text-base sm:text-lg leading-relaxed mb-6">
            Ich bin Philipp — Webentwickler aus Leidenschaft. Seit über 15 Jahren baue ich Websites, die nicht nur gut aussehen, sondern auch funktionieren. Mein Fokus liegt auf DSGVO-konformen, performanten Lösungen für kleine und mittlere Unternehmen in Österreich.
          </p>
          <p class="text-[#334155] text-base sm:text-lg leading-relaxed mb-8">
            Keine versteckten Kosten. Keine Lock-in-Verträge. Nur ehrliche Beratung und handgemachte Qualität — persönlich betreut von der ersten Idee bis zum Launch und darüber hinaus.
          </p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 py-8 border-y border-[#E2E8F0] mb-8">
          <div class="text-center">
            <p class="text-3xl sm:text-4xl font-extrabold text-[#4D7CFF]">15+</p>
            <p class="text-sm text-[#64748B] mt-1">Jahre</p>
          </div>
          <div class="text-center">
            <p class="text-3xl sm:text-4xl font-extrabold text-[#4D7CFF]">50+</p>
            <p class="text-sm text-[#64748B] mt-1">Projekte</p>
          </div>
          <div class="text-center">
            <p class="text-3xl sm:text-4xl font-extrabold text-[#4D7CFF]">100%</p>
            <p class="text-sm text-[#64748B] mt-1">DSGVO</p>
          </div>
        </div>

        <!-- Kontakt-Box -->
        <div class="bg-[#F8FAFC] rounded-2xl p-6 sm:p-8 border border-[#E2E8F0]">
          <p class="text-[#64748B] text-sm leading-relaxed mb-4">
            Bereit für den nächsten Schritt? Kontaktieren Sie mich direkt.
          </p>
          <div class="space-y-3">
            <!-- E-Mail -->
            <a href="mailto:info@einfach-online.dev" class="flex items-center gap-3 p-3 rounded-xl bg-white border border-[#E2E8F0] hover:border-[#4D7CFF]/30 transition-colors">
              <div class="w-8 h-8 rounded-lg bg-[#4D7CFF]/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4D7CFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <span class="text-sm font-medium text-[#0F172A]">E-Mail schreiben</span>
            </a>

            <!-- Anrufen -->
            <a href="tel:+436642550779" class="flex items-center gap-3 p-3 rounded-xl bg-white border border-[#E2E8F0] hover:border-[#4D7CFF]/30 transition-colors">
              <div class="w-8 h-8 rounded-lg bg-[#4D7CFF]/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4D7CFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <span class="text-sm font-medium text-[#0F172A]">Anrufen</span>
            </a>

            <!-- WhatsApp -->
            <a href="https://wa.me/436642550779" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-xl bg-white border border-[#E2E8F0] hover:border-green-500/30 transition-colors">
              <div class="w-8 h-8 rounded-lg bg-green-500/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              </div>
              <span class="text-sm font-medium text-[#0F172A]">WhatsApp</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <CookieBanner />
</Layout>
